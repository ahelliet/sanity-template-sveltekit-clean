{
  "name": "sveltekit-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "vite dev",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:unit": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@sanity/image-url": "^2.0.3",
    "groq": "^5.7.0",
    "mermaid": "^11.12.3",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@playwright/test": "^1.58.2",
    "@portabletext/svelte": "^3.0.1",
    "@portabletext/types": "^4.0.1",
    "@sanity/sveltekit": "^1.0.5",
    "@sanity/types": "^5.7.0",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-svelte-csf": "^5.0.11",
    "@storybook/addon-vitest": "^10.2.16",
    "@storybook/sveltekit": "^10.2.16",
    "@sveltejs/adapter-vercel": "^6.3.1",
    "@sveltejs/kit": "^2.50.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^20",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "autoprefixer": "^10.4.23",
    "eslint-plugin-storybook": "^10.2.16",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^10.2.16",
    "svelte": "^5.53.5",
    "svelte-check": "^4.3.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.0.18",
    "vitest-browser-svelte": "^2.0.2"
  }
}
